{
  "entity": {
    "sensor": {
      "active_zone": { "default": "mdi:sprinkler-variant" },
      "active_program": { "default": "mdi:calendar-clock" },
      "program": { "default": "mdi:calendar-text" },
      "controller_mode": {
        "default": "mdi:water-pump",
        "state": {
          "idle": "mdi:water-pump-off",
          "watering": "mdi:sprinkler",
          "rain_delayed": "mdi:weather-rainy",
          "disabled": "mdi:cancel"
        }
      },
      "zone_last_run_duration": { "default": "mdi:timer-outline" },
      "zone_last_run_at": { "default": "mdi:clock-outline" },
      "zone_estimated_volume": { "default": "mdi:water" },
      "zone_total_volume": { "default": "mdi:water-plus" }
    },
    "switch": {
      "zone": { "default": "mdi:sprinkler" }
    },
    "binary_sensor": {
      "rain_sensor": { "default": "mdi:weather-rainy" }
    },
    "number": {
      "zone_duration": { "default": "mdi:timer-cog-outline" },
      "rain_delay": { "default": "mdi:weather-rainy" }
    },
    "button": {
      "stop": { "default": "mdi:stop" },
      "advance": { "default": "mdi:skip-next" },
      "run_program": { "default": "mdi:play-circle-outline" }
    }
  },
  "services": {
    "start_irrigation": { "service": "mdi:sprinkler" },
    "raw_command": { "service": "mdi:console" }
  }
}
